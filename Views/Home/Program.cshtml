@{
    ViewData["Title"] = "Программа";
}

<div class="container my-5">
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold text-primary-sov">Программа партии</h1>
        <div class="header-divider mx-auto bg-accent-sov" style="width: 80px; height: 3px; border-radius: 2px;"></div>
    </div>

    <!-- 3 Main points -->
    <div class="row g-4 mb-5">
        <div class="col-12">
            <h2 class="h3 fw-bold text-primary-sov mb-4">Три опорных пункта</h2>
        </div>
        
        <div class="col-md-4">
            <div class="card-sov p-4 h-100 border-start border-4 border-danger">
                <div class="d-flex align-items-center mb-3">
                    <div class="bg-danger-sov rounded-circle p-3 text-white me-3">
                        <i class="fas fa-home fa-2x"></i>
                    </div>
                    <h3 class="h5 fw-bold mb-0">Жильё — семьям</h3>
                </div>
                <p class="text-muted">
                    Каждая семья с двумя и более детьми получает бесплатное благоустроенное жильё от государства. 
                    Дети — главный ресурс страны, и государство обязано обеспечить им достойные условия.
                </p>
            </div>
        </div>
        
        <div class="col-md-4">
            <div class="card-sov p-4 h-100 border-start border-4 border-primary">
                <div class="d-flex align-items-center mb-3">
                    <div class="bg-primary-sov rounded-circle p-3 text-white me-3">
                        <i class="fas fa-hand-holding-usd fa-2x"></i>
                    </div>
                    <h3 class="h5 fw-bold mb-0">Справедливая оплата созидательного труда</h3>
                </div>
                <p class="text-muted">
                    Учёные, инженеры, врачи, учителя, деятели культуры должны получать достойную долю от результатов 
                    своего труда. Мы против системы, где посредники и спекулянты зарабатывают больше создателей.
                </p>
            </div>
        </div>
        
        <div class="col-md-4">
            <div class="card-sov p-4 h-100 border-start border-4 border-warning">
                <div class="d-flex align-items-center mb-3">
                    <div class="bg-accent-sov rounded-circle p-3 text-white me-3">
                        <i class="fas fa-robot fa-2x"></i>
                    </div>
                    <h3 class="h5 fw-bold mb-0">Технологический суверенитет</h3>
                </div>
                <p class="text-muted">
                    Россия должна производить свои телефоны, станки, лекарства, музыкальные инструменты, автомобили, программное обеспечение, медицинские аппараты и т.д. — не хуже мировых аналогов. 
                    Мы не против импорта, мы за свободу выбора и уважение к своему производителю.
                </p>
            </div>
        </div>
    </div>

    <!-- Economic Platform -->
    <div class="row mb-5">
        <div class="col-12">
            <div class="p-5 bg-white rounded shadow-sm">
                <h2 class="h3 fw-bold text-primary-sov mb-4 border-bottom pb-3">
                    <i class="fas fa-chart-line text-accent-sov me-2"></i>Экономическая платформа
                </h2>
                
                <div class="mb-4">
                    <h4 class="h5 fw-bold text-danger-sov">Принцип: «Не отнять, а вовлечь»</h4>
                    <p class="text-muted">Мы предлагаем конструктивный подход к экономике, основанный на взаимной выгоде и общенациональных целях.</p>
                </div>

                <div class="row g-4">
                    <div class="col-md-6">
                        <div class="bg-light p-4 rounded h-100">
                            <h5 class="fw-bold"><i class="fas fa-building text-primary-sov me-2"></i>Национальный жилищный фонд «Дом для семьи»</h5>
                            <p class="text-muted small">
                                <strong>Финансирование:</strong> государство (отчисления от экспорта), бизнес (добровольные взносы в обмен на снижение налогов).<br/>
                                <strong>Итог:</strong> бизнес получает репутацию и льготы, народ — жильё.
                            </p>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="bg-light p-4 rounded h-100">
                            <h5 class="fw-bold"><i class="fas fa-lightbulb text-primary-sov me-2"></i>Фонд поддержки созидателей</h5>
                            <p class="text-muted small">
                                Доплаты авторам изобретений, гранты молодым специалистам, целевая поддержка отечественной 
                                медицины, образования и культуры за счет целевых отчислений.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Political Strategy -->
    <div class="row mb-4">
        <div class="col-12 text-center mb-4">
            <h2 class="h3 fw-bold text-primary-sov">Политическая стратегия</h2>
        </div>
        <div class="col-md-6 mb-4">
            <div class="card-sov p-4 text-center h-100">
                <i class="fas fa-landmark fa-3x text-primary-sov mb-3"></i>
                <h4 class="fw-bold mb-3">Парламентская работа</h4>
                <p class="text-muted">Принятие законов о жилье, налогах, защите интеллектуальной собственности и технологическом развитии.</p>
            </div>
        </div>
        <div class="col-md-6 mb-4">
            <div class="card-sov p-4 text-center h-100">
                <i class="fas fa-users-cog fa-3x text-primary-sov mb-3"></i>
                <h4 class="fw-bold mb-3">Экспертная деятельность</h4>
                <p class="text-muted">Разработка стратегических программ, участие в профильных советах при министерствах и ведомствах.</p>
            </div>
        </div>
    </div>
</div>
