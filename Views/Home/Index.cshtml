@{
    ViewData["Title"] = "Главная";
}

<!-- Hero Section -->
<section class="hero-section text-center position-relative overflow-hidden">
    <div class="container position-relative z-1">
        <h1 class="display-4 fw-bold text-primary-sov mb-3">Социал-демократическая партия «СОВесть»</h1>
        <h2 class="h3 mb-4 text-secondary">Мы помогаем людям, которые помогают стране</h2>
        <p class="lead mb-5 col-md-8 mx-auto">
            Передача ресурсов и богатств страны в руки трудового народа. Мы за то, чтобы человек 
            созидающего труда — инженер, врач, учитель, учёный, многодетный родитель — стал главным героем 
            российской политики.
        </p>
        <div class="d-flex justify-content-center gap-3">
            <a asp-controller="Home" asp-action="Program" class="btn btn-primary-sov btn-lg px-4 py-2">Узнать программу</a>
            <a asp-controller="Home" asp-action="Contacts" class="btn btn-accent-sov btn-lg px-4 py-2">Поддержать</a>
        </div>
    </div>
    <!-- Abstract background elements can go here -->
    <div class="position-absolute opacity-10" style="right: -5%; top: 10%; transform: scale(1.5);">
        <i class="fas fa-dove fa-10x text-primary-sov"></i>
    </div>
</section>

<!-- Values Section (3 cards) -->
<section class="py-5 bg-white">
    <div class="container text-center">
        <h2 class="mb-5 text-primary-sov fw-bold">Наши Ценности</h2>
        <div class="row g-4 justify-content-center">
            <div class="col-md-4">
                <div class="card-sov p-4 h-100 d-flex flex-column align-items-center">
                    <i class="fas fa-balance-scale fa-3x text-accent-sov mb-3"></i>
                    <h3 class="h4 fw-bold">Справедливость</h3>
                    <p class="text-muted mt-2">Честная оценка труда, борьба с паразитическим капиталом.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card-sov p-4 h-100 d-flex flex-column align-items-center">
                    <i class="fas fa-hands-helping fa-3x text-accent-sov mb-3"></i>
                    <h3 class="h4 fw-bold">Объединение</h3>
                    <p class="text-muted mt-2">Общественный договор между государством, бизнесом и народом.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card-sov p-4 h-100 d-flex flex-column align-items-center">
                    <i class="fas fa-fist-raised fa-3x text-accent-sov mb-3"></i>
                    <h3 class="h4 fw-bold">Воля</h3>
                    <p class="text-muted mt-2">Технологический суверенитет и независимость страны.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Key Program Points Section -->
<section class="py-5 bg-light">
    <div class="container">
        <h2 class="text-center mb-5 text-primary-sov fw-bold">Наша программа — три опорных пункта</h2>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="card-sov p-4 h-100 border-top border-4 border-danger">
                    <h3 class="h5 fw-bold mb-3"><i class="fas fa-home me-2 text-danger-sov"></i>Жильё — семьям</h3>
                    <p class="text-muted mb-4 flex-grow-1">Каждая семья с двумя и более детьми получает бесплатное благоустроенное жильё от государства. Дети — главный ресурс страны.</p>
                    <a asp-controller="Home" asp-action="Program" class="btn btn-outline-sov btn-sm mt-auto">Подробнее</a>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card-sov p-4 h-100 border-top border-4 border-primary">
                    <h3 class="h5 fw-bold mb-3"><i class="fas fa-coins me-2 text-primary-sov"></i>Справедливая оплата созидательного труда</h3>
                    <p class="text-muted mb-4 flex-grow-1">Учёные, инженеры, врачи, учителя должны получать достойную долю от результатов своего труда.</p>
                    <a asp-controller="Home" asp-action="Program" class="btn btn-outline-sov btn-sm mt-auto">Подробнее</a>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card-sov p-4 h-100 border-top border-4 border-warning">
                    <h3 class="h5 fw-bold mb-3"><i class="fas fa-microchip me-2 text-accent-sov"></i>Технологический суверенитет</h3>
                    <p class="text-muted mb-4 flex-grow-1">Россия должна производить свои товары — не хуже мировых аналогов. Мы за уважение к своему производителю.</p>
                    <a asp-controller="Home" asp-action="Program" class="btn btn-outline-sov btn-sm mt-auto">Подробнее</a>
                </div>
            </div>
        </div>
        
        <div class="mt-5 p-4 bg-white rounded shadow-sm border-start border-5 border-primary">
            <h4 class="fw-bold text-primary-sov mb-3"><i class="fas fa-user-graduate me-2"></i>Молодёжная политика</h4>
            <p class="fst-italic mb-0 pb-0">«Мы не учим патриотизму на словах. Мы создаём условия, при которых быть патриотом — выгодно и почётно. Молодёжь получает жильё, престиж профессий и отечественные технологии».</p>
        </div>
    </div>
</section>

<!-- First Bill Section -->
<section class="py-5 bg-white">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-md-6 order-md-2 mb-4 mb-md-0">
                <div class="p-5 rounded" style="background-color: var(--sov-blue);">
                    <i class="fas fa-file-contract fa-5x text-white opacity-50"></i>
                </div>
            </div>
            <div class="col-md-6 order-md-1">
                <h2 class="mb-4 text-primary-sov fw-bold">Первый законопроект</h2>
                <h3 class="h4 mb-3">«О праве на бесплатное жильё для семей с двумя и более детьми»</h3>
                <blockquote class="blockquote border-start border-4 border-danger ps-3 mb-4">
                    <p class="mb-0 fs-5">Каждая семья с двумя и более детьми получает благоустроенное жильё в собственность однократно (норма — не менее 18 кв. м на человека).</p>
                </blockquote>
                <a asp-controller="Home" asp-action="Bills" class="btn btn-primary-sov px-4">Читать далее</a>
            </div>
        </div>
    </div>
</section>

<!-- Call to Action -->
<section class="py-5 text-white text-center" style="background-color: var(--sov-blue);">
    <div class="container">
        <h2 class="mb-4 fw-bold">Поддержка</h2>
        <p class="lead mb-5 col-md-8 mx-auto">
            Хочешь платить меньше налогов — вкладывай в дома для семей и в будущее страны. 
            Не хочешь — плати по полной. Выбор за тобой.
        </p>
        <div class="d-flex justify-content-center gap-3">
             <a asp-controller="Home" asp-action="Contacts" class="btn btn-accent-sov btn-lg px-4">Стать волонтёром</a>
             <a asp-controller="Home" asp-action="Contacts" class="btn btn-outline-light btn-lg px-4">Подписаться на новости</a>
        </div>
    </div>
</section>
