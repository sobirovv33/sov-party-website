@{
    ViewData["Title"] = "О Партии";
}

<div class="container my-5">
    
    <!-- Hero Section with BIG Logo -->
    <div class="row mb-5 justify-content-center pt-4">
        <div class="col-lg-10 text-center">
            <div class="mb-5 d-flex justify-content-center">
                 <img src="~/images/logo_sov.png" alt="С.О.В. Logo" class="img-fluid drop-shadow rounded-5 p-3 bg-white" style="max-height: 400px; box-shadow: 0 10px 30px rgba(0,0,0,0.08);" />
            </div>
            
            <h1 class="display-3 fw-bold text-primary-sov mb-3">Партия «С.О.В.»</h1>
            <div class="header-divider mx-auto bg-accent-sov my-4" style="width: 100px; height: 4px; border-radius: 2px;"></div>
            
            <p class="lead fs-3 text-dark mb-5 lh-base px-md-5 mx-auto">
                <strong>Наша миссия:</strong> Передача ресурсов и богатств страны в руки трудового народа. Мы за то, чтобы человек созидающего труда — 
                инженер, врач, учитель, учёный, многодетный родитель — стал главным героем российской политики.
            </p>
        </div>
    </div>

    <!-- Values Grid -->
    <div class="row mb-5 pb-4">
        <div class="col-12 text-center mb-5">
            <h2 class="display-5 fw-bold text-primary-sov">Три столпа нашей партии</h2>
        </div>
        <div class="col-md-4 mb-4">
            <div class="card-sov p-5 h-100 text-center border-top border-5 border-danger shadow-sm">
                <i class="fas fa-balance-scale fa-4x text-accent-sov mb-4"></i>
                <h3 class="h3 fw-bold mb-3">Справедливость</h3>
                <p class="text-muted fs-5">Честная оценка и вознаграждение труда, системная борьба с монополиями и паразитическим капиталом.</p>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="card-sov p-5 h-100 text-center border-top border-5 border-primary shadow-sm">
                <i class="fas fa-hands-helping fa-4x text-accent-sov mb-4"></i>
                <h3 class="h3 fw-bold mb-3">Объединение</h3>
                <p class="text-muted fs-5">Честный общественный договор и надежное партнерство между государством, бизнесом и народом.</p>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="card-sov p-5 h-100 text-center border-top border-5 border-warning shadow-sm">
                <i class="fas fa-fist-raised fa-4x text-accent-sov mb-4"></i>
                <h3 class="h3 fw-bold mb-3">Воля</h3>
                <p class="text-muted fs-5">Абсолютный технологический суверенитет и политическая, экономическая независимость страны.</p>
            </div>
        </div>
    </div>

    <!-- Ideology & Audience -->
    <div class="row align-items-stretch mb-5">
        <div class="col-lg-5 mb-4 mb-lg-0">
            <div class="card-sov p-5 h-100 bg-primary-sov text-white rounded-4 border-0">
                <h2 class="h2 fw-bold mb-4 border-bottom border-secondary pb-3">
                    <i class="fas fa-landmark text-accent-sov me-3"></i>Идеология
                </h2>
                <ul class="list-unstyled fs-4 lh-lg mt-4">
                    <li><i class="fas fa-check text-accent-sov me-3"></i>Социал-демократия</li>
                    <li><i class="fas fa-check text-accent-sov me-3"></i>Социальная справедливость</li>
                    <li><i class="fas fa-check text-accent-sov me-3"></i>Технологический суверенитет</li>
                    <li><i class="fas fa-check text-accent-sov me-3"></i>Патриотизм созидания</li>
                </ul>
            </div>
        </div>
        
        <div class="col-lg-7">
            <div class="card-sov p-5 h-100 bg-white rounded-4 border-0 shadow-sm border-start border-5 border-accent-sov">
                <h2 class="h2 fw-bold text-primary-sov mb-4 border-bottom pb-3">Для кого мы работаем</h2>
                <p class="fs-5 text-muted mb-4">Наша политика направлена на поддержку фундамента общества:</p>
                <div class="row g-4 mt-2">
                    <div class="col-md-6 d-flex">
                        <div class="me-3"><i class="fas fa-baby-carriage fa-2x text-danger-sov"></i></div>
                        <div>
                            <strong class="d-block fs-5 text-dark">Многодетные семьи</strong>
                            <span class="text-muted small">Основа будущего нации</span>
                        </div>
                    </div>
                    <div class="col-md-6 d-flex">
                        <div class="me-3"><i class="fas fa-microscope fa-2x text-primary-sov"></i></div>
                        <div>
                            <strong class="d-block fs-5 text-dark">Инженеры и учёные</strong>
                            <span class="text-muted small">Создатели технологического щита</span>
                        </div>
                    </div>
                    <div class="col-md-6 d-flex">
                        <div class="me-3"><i class="fas fa-user-md fa-2x text-success"></i></div>
                        <div>
                            <strong class="d-block fs-5 text-dark">Врачи и учителя</strong>
                            <span class="text-muted small">Хранители здоровья и разума нации</span>
                        </div>
                    </div>
                    <div class="col-md-6 d-flex">
                        <div class="me-3"><i class="fas fa-hard-hat fa-2x text-warning"></i></div>
                        <div>
                            <strong class="d-block fs-5 text-dark">Рабочие и бюджетники</strong>
                            <span class="text-muted small">Фундамент государства</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
