@{
    ViewData["Title"] = "Команда";
}

<div class="container my-5">
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold text-primary-sov">Наша команда</h1>
        <div class="header-divider mx-auto bg-accent-sov" style="width: 80px; height: 3px; border-radius: 2px;"></div>
        <p class="lead text-muted mt-4">
            Профессионалы своего дела, объединившиеся ради созидательного будущего страны.
        </p>
    </div>

    <!-- Team Members Cards -->
    <div class="row justify-content-center g-4">
        <!-- Candidate 1 -->
        <div class="col-md-4">
            <div class="card-sov p-4 text-center h-100 position-relative overflow-hidden">
                <div class="mb-4 d-flex justify-content-center">
                    <div class="rounded-circle bg-light d-flex align-items-center justify-content-center border border-3 border-danger" style="width: 150px; height: 150px;">
                        <i class="fas fa-hands-helping fa-4x text-primary-sov opacity-50"></i>
                    </div>
                </div>
                <h3 class="h4 fw-bold mb-1">Собиров Мухаммад Музафарович</h3>
                <h4 class="text-accent-sov h6 mb-3">Представитель созидателей</h4>
                <p class="text-muted small">
                    Отвечает за социальный сектор, защиту бюджетников, работников здравоохранения и молодёжную политику. 
                    Активный гражданин и голос созидательного труда.
                </p>
            </div>
        </div>

        <!-- Candidate 2 -->
        <div class="col-md-4">
            <div class="card-sov p-4 text-center h-100 position-relative overflow-hidden">
                <div class="mb-4 d-flex justify-content-center">
                    <div class="rounded-circle bg-light d-flex align-items-center justify-content-center border border-3 border-primary" style="width: 150px; height: 150px;">
                        <i class="fas fa-user-tie fa-4x text-primary-sov opacity-50"></i>
                    </div>
                </div>
                <h3 class="h4 fw-bold mb-1">Мамаев Максим Алексеевич</h3>
                <h4 class="text-accent-sov h6 mb-3">Лидер-идеолог</h4>
                <p class="text-muted small">
                    Отвечает за идеологию партии «С.О.В.» и формирование ценностей. Вдохновляет команду на достижение 
                    справедливого будущего для народа.
                </p>
            </div>
        </div>

        <!-- Candidate 3 -->
        <div class="col-md-4">
            <div class="card-sov p-4 text-center h-100 position-relative overflow-hidden">
                <div class="mb-4 d-flex justify-content-center">
                    <div class="rounded-circle bg-light d-flex align-items-center justify-content-center border border-3 border-warning" style="width: 150px; height: 150px;">
                        <i class="fas fa-chart-bar fa-4x text-primary-sov opacity-50"></i>
                    </div>
                </div>
                <h3 class="h4 fw-bold mb-1">Саидалимов Ибрагим Порсохуджаевич</h3>
                <h4 class="text-accent-sov h6 mb-3">Экономист-хозяйственник</h4>
                <p class="text-muted small">
                    Курирует экономический блок, формирование национальных фондов и реформу налогообложения. 
                    Аналитик с системным подходом к управлению.
                </p>
            </div>
        </div>
    </div>
</div>
